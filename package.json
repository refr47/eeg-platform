{
	"name": "energy-platform",
	"version": "1.0.3",
	"description": "A simple and ready-to-use Express.js starter kit with MongoDB, JWT auth, file uploads, and proper MVC folder structure.",
	"type": "module",
	"main": "./cli.js",
	"bin": {
		"node-express-kit": "./cli.js"
	},
	"scripts": {
    "type": "module",
		"start": "node server.js",
		"dev": "nodemon server.js",
		"lint": "eslint '**/*.js'",
      "format": "prettier --write '**/*.js'",
      "check": "eslint '**/*.js' && prettier --check '**/*.js'",
      "lint:fix": "eslint '**/*.js' --fix && prettier --write '**/*.js'i"
	},
	"keywords": [
		"express",
		"nodejs",
		"starter-kit",
		"mvc",
		"mongodb",
		"jwt",
		"authentication",
		"boilerplate"
	],
	"author": "Franz Reitinger <retfra@gmail.com>",
	"license": "ISC",
	"files": [
		"template/",
		"cli.js"
	],
	"dependencies": {
		"bcryptjs": "^3.0.2",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.5",
		"dotenv": "^16.4.7",
		"express": "^5.1.0",
		"jsonwebtoken": "^9.0.2",
		"mongoose": "^8.13.2",
		"morgan": "^1.10.0",
		"multer": "^1.4.5-lts.2",
		"nodemailer": "^6.10.0"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"cjstoesm": "^3.0.0",
		"eslint": "^10.1.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.5",
		"nodemon": "^3.1.9",
		"prettier": "^3.8.1"
	}
}
