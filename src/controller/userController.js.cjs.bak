import catchAsyncErrors from "../helpers/catchAsyncErrors.js"
import ErrorHandler from "../utils/ErrorHandler.js";
import SuccessHandler from "../utils/SucessHandler.js"
import User from "../model/userModel.js";
import bcrypt from "bcryptjs";
import { authToken, options } from "../utils/Token.js"
const salt = process.env.SALT || 10;

// Register User - 

export const registerUser = catchAsyncErrors(async (req, res, next) => {
    const { password } = req.body;

    req.body.password = await bcrypt.hash(password, salt);
    const users = await User.create(req.body);
    if (!users) {
        return next(new ErrorHandler("user not created", 403));
    }
    return new SuccessHandler(201, "user created sucessFully", users).send(res);
});

//  Find Users - 

export const getUsers = catchAsyncErrors(async (req, res, next) => {
    const users = await User.find();
    if (!users) {
        return next(new ErrorHandler("User Not Found", 403))
    }
    return new SuccessHandler(200, "users Found", users).send(res);
});

//  get Users Profile  - 

export const getProfile = catchAsyncErrors(async (req, res, next) => {

    const userDetail = await User.findById(req.user.id);
    if (!userDetail) {
        return next(new ErrorHandler("user  not Found ", 404));
    };

    return new SuccessHandler(200, "user Found", userDetail).send(res);

})

