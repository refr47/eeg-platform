// login User -  
export const loginUser = catchAsyncErrors(async (req, res, next) => {

    const { id, password } = req.body;

    if (!id || !password) { return next(new ErrorHandler("id and password is mandatory", 400)) }
    const user = await User.findOne({ $or: [{ userName: id }, { email: id }, { phone: id }] })
    if (!user) {
        return next(new ErrorHandler("User Not Found", 400));
    }
    const matchPassword = await bcrypt.compare(password, user.password); // comparing plan and Hashed password -

    if (!matchPassword) {
        return next(new ErrorHandler("user id and password not matched ", 404))
    }
    const token = authToken({ user: user });
    res.cookie("authToken", token, options), new SuccessHandler(200, "user logged-in sucessfully", user).send(res);

});

//  logout User -
export const logoutUser = catchAsyncErrors(async (req, res, next) => {

    res.clearCookie("authToken", options), new SuccessHandler(200, "user logged-out sucessfully", null).send(res);

});

