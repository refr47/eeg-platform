import userModel from "../model/userModel.js"
import ErrorHandler from "../utils/ErrorHandler.js"
import catchAsyncErrors from "../helpers/catchAsyncErrors.js";
import jwt from "jsonwebtoken"

// if token matched then give access -

export const isAuthenticated = catchAsyncErrors(async (req, res, next) => {
    const token = req.cookies.authToken;

    if (!token) {
        return next(new ErrorHandler("Please Login First", 401));
    };

    const decodedData = jwt.verify(token, process.env.JWT_SECRET);

    req.user = await userModel.findById(decodedData.user._id);

    next();

});

// verify Role to Give the access to User -   

export const isAuthorised = (...roles) => {
    return (req, res, next) => {

        if (!roles.includes(req.user.role)) {
            return next(new ErrorHandler("You are not Authorized to Access the Resource", 403));
        };
        next();
    };
};